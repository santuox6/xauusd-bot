# Copy this file to .env and fill in your values
# Then: source .env  (Linux/Mac)
#   or: set /p < .env  (Windows)

# REQUIRED — Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# OPTIONAL — How often to check prices (seconds). Default: 60
CHECK_INTERVAL=60

# OPTIONAL — SQLite database file path. Default: alerts.db
DB_PATH=alerts.db
